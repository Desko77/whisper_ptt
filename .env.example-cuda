# Whisper-PTT (CUDA) — example config. Copy to .env and set your values.
# Requires an NVIDIA GPU with CUDA support.

# Whisper model
WHISPER_PTT_WHISPER_MODEL=large-v3
# Whisper language: en, ru, de, fr or other code
WHISPER_PTT_WHISPER_LANGUAGE=en
WHISPER_PTT_WHISPER_INITIAL_PROMPT=English speech.

# Whisper anti-repetition (prevents hallucinated duplicate text)
# no_repeat_ngram_size: block repeated n-grams of this size (0 = off, 3 = good default)
WHISPER_PTT_WHISPER_NO_REPEAT_NGRAM_SIZE=3
# repetition_penalty: penalize previously generated tokens (1.0 = off, >1.0 = penalize)
WHISPER_PTT_WHISPER_REPETITION_PENALTY=1.1
# hallucination_silence_threshold: skip segments over silence longer than N sec (0 = off)
WHISPER_PTT_WHISPER_HALLUCINATION_SILENCE_THRESHOLD=2.0

# Hotkey (default: alt)
WHISPER_PTT_HOTKEY=alt

# LLM transform (true/false) — optional, OFF by default
WHISPER_PTT_USE_LLM_TRANSFORM=false
# Backend: ollama (Ollama native API) or openai (OpenAI-compatible: LM Studio, llama.cpp, etc.)
WHISPER_PTT_LLM_BACKEND=ollama
# Model name (as known to your backend)
WHISPER_PTT_LLM_MODEL=gemma3:12b
# API URL (defaults: ollama=http://localhost:11434/api/generate, openai=http://localhost:1234/v1/chat/completions)
WHISPER_PTT_LLM_URL=http://localhost:11434/api/generate
# API key (only needed if your openai-compatible server requires it; leave empty otherwise)
# WHISPER_PTT_LLM_API_KEY=
# Reasoning/thinking for models that support it (Gemma 4, etc.): none, low, medium, high, off
# WHISPER_PTT_LLM_REASONING_EFFORT=none
# LLM transform prompt: optional. Use {detected_lang} and {raw_text}. Omit for built-in default.
# WHISPER_PTT_LLM_TRANSFORM_PROMPT="Fix the transcription. Language: {detected_lang}. Return only cleaned text.\n\n{raw_text}"

# Copy to clipboard (true/false)
WHISPER_PTT_COPY_TO_CLIPBOARD=true
# Paste to active window (true/false)
WHISPER_PTT_PASTE_TO_ACTIVE_WINDOW=true
# Paste method: auto (detect terminals) | ctrl+v | ctrl+shift+v | shift+insert
WHISPER_PTT_PASTE_METHOD=auto
# Clipboard after paste (only when Paste is on): restore | clear | preserve
# restore = put back what was in clipboard before; clear = empty clipboard; preserve = leave transcription
WHISPER_PTT_CLIPBOARD_AFTER_PASTE_POLICY=restore
# Keys after paste: key(s) to send (enter, ctrl+enter, or empty/none)
WHISPER_PTT_KEYS_AFTER_PASTE=enter

# Audio device: "default" for system default, or device name substring (e.g. "Realtek", "Blue Yeti")
WHISPER_PTT_AUDIO_DEVICE=default
# Audio: sample rate, chunk size
WHISPER_PTT_SAMPLE_RATE=16000
WHISPER_PTT_CHUNK_SIZE=1024

# Prebuffer (sec), padding (sec), min frames, silence gate
WHISPER_PTT_PREBUFFER_SEC=0.5
WHISPER_PTT_PADDING_SEC=0.2
WHISPER_PTT_MIN_FRAMES=5
WHISPER_PTT_SILENCE_AMPLITUDE=750

# Chunked transcription for long recordings (0 = disabled)
# When recording exceeds this duration, chunks are transcribed in background while you speak
WHISPER_PTT_CHUNK_DURATION_SEC=15
# Audio overlap between chunks (seconds) — prevents cutting words at boundaries
WHISPER_PTT_CHUNK_OVERLAP_SEC=2.0
